# Environment
PORT=3090
NODE_ENV=production

# Database
DATABASE_URL=postgresql://agentx:agentx@localhost:5432/agentx_gateway

# Redis (rate limiting & sessions)
REDIS_URL=redis://localhost:6379

# JWT (generate: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# Master encryption key for tenant API keys at rest (hex, 32 bytes)
MASTER_ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-key

# Session TTL (seconds)
SESSION_TTL_SEC=86400
